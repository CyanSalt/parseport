{
  "name": "parseport",
  "version": "0.1.2",
  "description": "Get static value from a JavaScript or TypeScript file",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint --fix './**/*.{js,ts}'",
    "lint:ci": "eslint --max-warnings 0 './**/*.{js,ts}'",
    "prepack": "tsdown",
    "release": "release-it",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyanSalt/parseport.git"
  },
  "keywords": [
    "module",
    "babel"
  ],
  "author": "CyanSalt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CyanSalt/parseport/issues"
  },
  "homepage": "https://github.com/CyanSalt/parseport#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.5.0",
    "@cyansalt/tsconfig": "^3.0.2",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "ast-kit": "^2.2.0",
    "globals": "^17.4.0",
    "oxc-resolver": "^11.19.1"
  }
}
